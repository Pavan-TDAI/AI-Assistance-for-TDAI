{
  "name": "personal-ai-agent-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "pnpm --filter @personal-ai/server dev",
    "dev:web": "pnpm --filter @personal-ai/web dev",
    "start:server": "pnpm --filter @personal-ai/server start",
    "build": "pnpm --filter @personal-ai/server build && pnpm --filter @personal-ai/web build",
    "build:ci": "pnpm -r typecheck && pnpm test && pnpm --filter @personal-ai/server build && pnpm --filter @personal-ai/web build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "seed": "pnpm --filter @personal-ai/server seed",
    "playwright:install": "pnpm --filter @personal-ai/local-tools exec playwright install",
    "lint": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
