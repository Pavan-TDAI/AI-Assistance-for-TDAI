{
  "name": "@personal-ai/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@personal-ai/agent-core": "workspace:*",
    "@personal-ai/db": "workspace:*",
    "@personal-ai/google-connectors": "workspace:*",
    "@personal-ai/local-tools": "workspace:*",
    "@personal-ai/shared": "workspace:*",
    "@personal-ai/tool-registry": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0"
  }
}
